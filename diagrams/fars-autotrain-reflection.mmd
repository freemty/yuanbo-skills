%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e8f4fd', 'primaryBorderColor': '#4a90d9', 'fontSize': '14px'}}}%%
flowchart TB
    subgraph input["Experiment Output"]
        SOLVE["solve_out\n(per job)"]
        METRICS["metrics.json"]
    end

    subgraph perjob["Per-Job Parallel"]
        S0["S0: Summarizer\nTrajectoryBrief"]
        S1["S1: Evidence Extractor\nEvidence[]"]
    end

    subgraph crossjob["Cross-Job Aggregate"]
        S2["S2: Pattern Miner\nPattern[] (>=2 evidence)"]
    end

    subgraph gen["Generation"]
        HARNESS["current harness\nagents/claude_vN/"]
        S3["S3: Harness Generator\nHarnessChange[]"]
    end

    subgraph version["Agent Versioning"]
        NEW["agents/claude_v(N+1)/"]
        VAL["Validator\nA/B experiment"]
    end

    SOLVE & METRICS --> S0
    S0 --> S1
    S1 -->|"aggregate\nall jobs"| S2
    S2 --> S3
    HARNESS --> S3
    S3 --> NEW
    NEW --> VAL

    VAL -->|"feedback\nnext iteration"| input

    G1{{"Gate 1\nbriefs review"}}
    G2{{"Gate 2\npatterns review"}}
    G3{{"Gate 3\nchanges review"}}

    S1 -.-> G1
    S2 -.-> G2
    S3 -.-> G3

    style input fill:#e8f4fd,stroke:#4a90d9
    style perjob fill:#e8f5e9,stroke:#4caf50
    style crossjob fill:#fff3e0,stroke:#ff9800
    style gen fill:#f3e5f5,stroke:#9c27b0
    style version fill:#fce4ec,stroke:#e91e63
    style G1 fill:#fffde7,stroke:#fbc02d
    style G2 fill:#fffde7,stroke:#fbc02d
    style G3 fill:#fffde7,stroke:#fbc02d
